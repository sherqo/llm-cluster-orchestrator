      "seed": 651921020,
      "version": 659,
      "versionNonce": 1772331204,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777325381962,
      "link": null,
      "locked": false,
      "text": "Each agent is responsible for doing\nactions on the machine it acces on behalf\nof the master. Actions like:\n- adding new worker node\n- kill exsiting worker node\n- send machine specs utilization\nThe agent doesn't store any data. ",
      "fontSize": 13,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Each agent is responsible for doing actions on the machine it acces on behalf of the master. Actions like:\n- adding new worker node\n- kill exsiting worker node\n- send machine specs utilization\nThe agent doesn't store any data. ",
      "autoResize": false,
      "lineHeight": 1.25,
      "hasTextLink": false
